<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base theme OLED/AMOLED -->
    <style name="Theme.TeleMusic" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Backgrounds -->
        <item name="android:windowBackground">@color/background_primary</item>
        <item name="colorSurface">@color/background_primary</item>
        <item name="colorSurfaceVariant">@color/background_secondary</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>

        <!-- Primary -->
        <item name="colorPrimary">@color/accent_blue</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorPrimaryContainer">@color/background_card</item>
        <item name="colorOnPrimaryContainer">@color/text_primary</item>

        <!-- Secondary -->
        <item name="colorSecondary">@color/accent_blue_dark</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="colorSecondaryContainer">@color/background_card</item>
        <item name="colorOnSecondaryContainer">@color/text_primary</item>

        <!-- Tertiary -->
        <item name="colorTertiary">@color/accent_purple</item>
        <item name="colorOnTertiary">@color/black</item>

        <!-- Error -->
        <item name="colorError">@color/accent_red</item>
        <item name="colorOnError">@color/black</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/status_bar</item>
        <item name="android:navigationBarColor">@color/navigation_bar</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>

        <!-- Text -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_hint</item>

        <!-- Ripple -->
        <item name="colorControlHighlight">@color/ripple</item>

        <!-- Shapes (Pixel style) -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeSmall</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeMedium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeLarge</item>

        <!-- Fonts -->
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <!-- Splash theme -->
    <style name="Theme.TeleMusic.Splash" parent="Theme.TeleMusic">
        <item name="android:windowBackground">@drawable/splash_background</item>
    </style>

    <!-- Pixel-style shapes -->
    <style name="ShapeSmall" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>

    <style name="ShapeMedium" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

    <style name="ShapeLarge" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <!-- Pixel-style Card -->
    <style name="Widget.PixelCard" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/background_card</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/divider</item>
        <item name="contentPadding">16dp</item>
    </style>

    <!-- Pixel-style Button -->
    <style name="Widget.PixelButton" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/accent_blue</item>
        <item name="android:textColor">@color/black</item>
        <item name="cornerRadius">24dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Pixel-style Outlined Button -->
    <style name="Widget.PixelOutlinedButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/divider_strong</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="cornerRadius">24dp</item>
    </style>

    <!-- Pixel-style Text Button -->
    <style name="Widget.PixelTextButton" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/accent_blue</item>
    </style>

    <!-- Pixel-style Input -->
    <style name="Widget.PixelTextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/divider_strong</item>
        <item name="hintTextColor">@color/accent_blue</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="android:textColorHint">@color/text_hint</item>
    </style>

    <!-- Pixel-style Switch -->
    <style name="Widget.PixelSwitch" parent="Widget.AppCompat.CompoundButton.Switch">
        <item name="thumbTint">@color/switch_thumb</item>
        <item name="trackTint">@color/switch_track_off</item>
    </style>

    <!-- Pixel-style Bottom Navigation -->
    <style name="Widget.PixelBottomNav" parent="Widget.Material3.BottomNavigationView">
        <item name="backgroundTint">@color/bottom_nav_background</item>
        <item name="itemIconTint">@color/bottom_nav_color</item>
        <item name="itemTextColor">@color/bottom_nav_color</item>
        <item name="itemRippleColor">@color/ripple</item>
        <item name="elevation">0dp</item>
    </style>

    <!-- Pixel-style Top App Bar -->
    <style name="Widget.PixelTopAppBar" parent="Widget.Material3.Toolbar">
        <item name="android:background">@color/background_primary</item>
        <item name="titleTextColor">@color/text_primary</item>
        <item name="navigationIconTint">@color/text_primary</item>
        <item name="elevation">0dp</item>
    </style>

    <!-- Pixel-style Dialog -->
    <style name="Theme.PixelDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorSurface">@color/background_dialog</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeMedium</item>
    </style>

    <!-- Chip Text Style -->
    <style name="ChipTextStyle">
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
</resources>
