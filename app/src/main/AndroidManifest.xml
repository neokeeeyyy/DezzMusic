<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.dezzmusic">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".TeleMusicApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.TeleMusic"
        android:usesCleartextTraffic="true">

        <activity
            android:name=".ui.LoginActivity"
            android:exported="true"
            android:theme="@style/Theme.TeleMusic.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.MainActivity"
            android:exported="false"
            android:theme="@style/Theme.TeleMusic" />

        <activity
            android:name=".ui.PlayerActivity"
            android:exported="false"
            android:theme="@style/Theme.TeleMusic"
            android:launchMode="singleTop" />

        <activity
            android:name=".ui.ChatActivity"
            android:exported="false"
            android:theme="@style/Theme.TeleMusic" />

        <activity
            android:name=".ui.SearchActivity"
            android:exported="false"
            android:theme="@style/Theme.TeleMusic"
            android:windowSoftInputMode="stateVisible|adjustResize" />

        <activity
            android:name=".ui.LibraryActivity"
            android:exported="false"
            android:theme="@style/Theme.TeleMusic" />

        <activity
            android:name=".ui.SettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.TeleMusic" />

        <activity
            android:name=".ui.SettingsDetailActivity"
            android:exported="false"
            android:theme="@style/Theme.TeleMusic" />

        <activity
            android:name=".ui.LibraryDetailActivity"
            android:exported="false"
            android:theme="@style/Theme.TeleMusic" />

        <activity
            android:name=".ui.DeezloadBotActivity"
            android:exported="false"
            android:theme="@style/Theme.TeleMusic" />

        <service
            android:name=".music.MusicService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback">
            <intent-filter>
                <action android:name="android.intent.action.MEDIA_BUTTON" />
            </intent-filter>
        </service>

        <receiver
            android:name=".ui.MusicNotificationReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.dezzmusic.PLAY_PAUSE" />
                <action android:name="com.dezzmusic.NEXT" />
                <action android:name="com.dezzmusic.PREVIOUS" />
                <action android:name="com.dezzmusic.STOP" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
